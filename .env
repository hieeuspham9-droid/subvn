# =====================================================
# SUB.VN API - ENVIRONMENT CONFIGURATION
# =====================================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME=SUB.VN
APP_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=sub_vn

# JWT Secret (Change this to a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email Configuration (NodeMailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=SUB.VN <noreply@sub.vn>

# Contact Information
CONTACT_EMAIL=dwen.khachieu@gmail.com
CONTACT_ZALO=0972562495
CONTACT_FACEBOOK=OnlyLove

# Payment Gateway
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn

# JustAnotherPanel API
JAP_API_URL=https://justanotherpanel.com/api/v2
JAP_API_KEY=90e0a5da66fc9782e1d2bc8fcc93aa4f

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=30
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Minimum Deposit Amount (VND)
MIN_DEPOSIT=10000

# Auto Cancel Pending Orders (hours)
AUTO_CANCEL_PENDING_HOURS=24

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Cronjob Settings
ENABLE_CRONJOBS=true
ORDER_CHECK_INTERVAL=*/5 * * * *
BALANCE_CHECK_INTERVAL=0 */6 * * *
